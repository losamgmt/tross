{
  "$schema": "./nav-config.schema.json",
  "version": "1.6.0",
  "mobileNavigationStyle": "bottomNav",
  "_comments": {
    "permissionResource": "Maps to permissions.json resource for nav visibility. Distinct from entity-metadata.json rlsResource which controls row-level data access.",
    "syntheticResources": "dashboard, admin_panel, preferences are synthetic (non-entity) resources defined in permissions.json for nav visibility checks.",
    "sidebarStrategies": "Define which groups/entities appear in sidebar based on route context. Routes declare their strategy via routeStrategies.",
    "menuBehaviors": "Defines display behavior for each menu type. displayMode: 'dropdown' = always anchored to trigger, 'adaptive' = responsive based on screen size (popup on desktop, bottom sheet on mobile).",
    "mobileNavigationStyle": "Mobile navigation pattern: 'bottomNav' = bottom navigation bar (modern Material, no hamburger), 'drawer' = hamburger menu with side drawer (no bottom nav). One or the other, not both."
  },
  "menuBehaviors": {
    "userMenu": {
      "displayMode": "dropdown",
      "_comment": "User avatar menu always appears as dropdown anchored to avatar, never bottom sheet"
    },
    "sidebar": {
      "displayMode": "adaptive",
      "_comment": "Sidebar adapts: drawer on mobile, persistent on desktop"
    },
    "mobileNav": {
      "displayMode": "adaptive",
      "_comment": "Mobile nav items with children show adaptive picker"
    }
  },
  "sidebarStrategies": {
    "app": {
      "label": "Main Navigation",
      "groups": [
        "customers",
        "resources",
        "work",
        "finance",
        "admin"
      ],
      "includeEntities": true,
      "showDashboard": true
    },
    "admin": {
      "label": "Administration",
      "groups": [
        "customers",
        "resources",
        "work",
        "finance",
        "admin"
      ],
      "includeEntities": true,
      "sections": [
        {
          "id": "home",
          "label": "Home",
          "icon": "dashboard_outlined",
          "route": "/admin",
          "order": 0,
          "permissionResource": "admin_panel"
        },
        {
          "id": "entities",
          "label": "Entities",
          "icon": "dataset_outlined",
          "order": 1,
          "isGrouper": true,
          "permissionResource": "admin_panel"
        },
        {
          "id": "logs",
          "label": "Logs",
          "icon": "history_outlined",
          "order": 2,
          "route": "/admin/system/logs",
          "permissionResource": "admin_panel"
        },
        {
          "id": "files",
          "label": "Files",
          "icon": "folder_outlined",
          "order": 3,
          "route": "/admin/system/files",
          "permissionResource": "admin_panel"
        }
      ]
    }
  },
  "routeStrategies": {
    "/home": "app",
    "/admin": "admin",
    "/admin/*": "admin",
    "/settings": "app"
  },
  "publicRoutes": [
    {
      "id": "root",
      "path": "/"
    },
    {
      "id": "login",
      "path": "/login"
    },
    {
      "id": "callback",
      "path": "/callback"
    },
    {
      "id": "error",
      "path": "/error"
    },
    {
      "id": "unauthorized",
      "path": "/unauthorized"
    },
    {
      "id": "notFound",
      "path": "/not-found"
    }
  ],
  "groups": [
    {
      "id": "main",
      "label": "Main",
      "icon": "dashboard_outlined",
      "order": 0
    },
    {
      "id": "customers",
      "label": "Customers",
      "icon": "business_outlined",
      "order": 1
    },
    {
      "id": "resources",
      "label": "Resources",
      "icon": "engineering_outlined",
      "order": 2
    },
    {
      "id": "work",
      "label": "Work",
      "icon": "build_outlined",
      "order": 3
    },
    {
      "id": "finance",
      "label": "Finance",
      "icon": "payments_outlined",
      "order": 4
    },
    {
      "id": "admin",
      "label": "Admin",
      "icon": "admin_panel_settings_outlined",
      "order": 98
    }
  ],
  "staticItems": [
    {
      "id": "dashboard",
      "label": "Dashboard",
      "icon": "dashboard_outlined",
      "route": "/",
      "group": "main",
      "order": 0,
      "permissionResource": "dashboard",
      "menuType": "sidebar"
    },
    {
      "id": "admin_panel",
      "label": "Admin",
      "icon": "admin_panel_settings_outlined",
      "route": "/admin",
      "group": "account",
      "order": 0,
      "permissionResource": "admin_panel",
      "menuType": "userMenu"
    },
    {
      "id": "settings",
      "label": "Settings",
      "icon": "settings_outlined",
      "route": "/settings",
      "group": "account",
      "order": 1,
      "menuType": "userMenu"
    }
  ],
  "entityPlacements": {
    "approval_request": {
      "group": "admin",
      "order": 5
    },
    "asset": {
      "group": "customers",
      "order": 4
    },
    "contract": {
      "group": "finance",
      "order": 1
    },
    "customer": {
      "group": "customers",
      "order": 1
    },
    "department": {
      "group": "admin",
      "order": 2
    },
    "inventory": {
      "group": "resources",
      "order": 2
    },
    "invoice": {
      "group": "finance",
      "order": 2
    },
    "maintenance_schedule": {
      "group": "work",
      "order": 6
    },
    "payment": {
      "group": "finance",
      "order": 2
    },
    "property": {
      "group": "customers",
      "order": 2
    },
    "purchase_order": {
      "group": "resources",
      "order": 4
    },
    "quote": {
      "group": "work",
      "order": 2
    },
    "receipt": {
      "group": "finance",
      "order": 3
    },
    "recommendation": {
      "group": "work",
      "order": 4
    },
    "role": {
      "group": "admin",
      "order": 2
    },
    "service_agreement": {
      "group": "work",
      "order": 7
    },
    "service_template": {
      "group": "work",
      "order": 5
    },
    "subcontractor": {
      "group": "resources",
      "order": 3
    },
    "technician": {
      "group": "resources",
      "order": 1
    },
    "unit": {
      "group": "customers",
      "order": 3
    },
    "user": {
      "group": "admin",
      "order": 1
    },
    "vendor": {
      "group": "resources",
      "order": 3
    },
    "visit": {
      "group": "work",
      "order": 3
    },
    "work_order": {
      "group": "work",
      "order": 1
    }
  }
}